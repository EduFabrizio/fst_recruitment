<launch>
    <!-- 1. Carrega as coordenadas do YAML direto para o Servidor de Parametros -->
    <!-- $(find task2) descobre automaticamente o caminho da sua pasta! -->
    <rosparam command="load" file="$(find task2)/config/task2_coords.yaml" />

    <!-- 2. Lanca o Primeiro No (Publicador) -->
    <!-- output="screen" faz com que os ROS_INFO aparecam no terminal -->
    <node pkg="task2" type="pub_node2" name="node_publisher" output="screen" />

    <!-- 3. Lanca o Segundo No (Subscriber / Marcadores) -->
    <node pkg="task2" type="sub_node2" name="node_subscriber" output="screen" />

    <!-- 4. Lanca o Simulador RViz ja com as configuracoes visuais salvas -->
    <!-- args="-d ..." carrega o arquivo config.rviz automaticamente -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find task2)/rviz/config.rviz" required="true" />

</launch>